.page {
  --navy: #3f2d18;
  --navy-800: #2d2018;
  --navy-900: #1b1410;
  --navy-950: #0f0b08;
  --gold: #efba81;
  --gold-300: #f5d4b2;
  --gold-600: #ba8b57;
  --charcoal: #2d2926;
  --charcoal-60: rgba(45, 41, 38, 0.6);
  --charcoal-80: rgba(45, 41, 38, 0.8);
  --line: #ece4d7;
  --line-2: #f3ece0;
  --surface: #faf5ee;
  --surface-2: #f4ecde;
  background: #fff;
  color: var(--charcoal);
  font-feature-settings: "ss01", "cv11";
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}
.page h1,
.page h2,
.page h3,
.page h4 {
  margin: 0;
  letter-spacing: -0.02em;
  color: var(--navy);
}
.page p {
  margin: 0;
}

/* ========= NAV ========= */
.navWrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 14px 0;
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
.navWrap.scrolled {
  padding: 8px 0;
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: saturate(1.5) blur(18px);
  -webkit-backdrop-filter: saturate(1.5) blur(18px);
  border-bottom: 1px solid rgba(63, 45, 24, 0.06);
}
.nav {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}
.nav > .brand {
  flex: 1;
}
.nav > .navCta {
  flex: 1;
  justify-content: flex-end;
}
.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 700;
  font-size: 17px;
  color: #fff;
  letter-spacing: -0.01em;
  transition: color 0.25s;
}
.navWrap.scrolled .brand {
  color: var(--navy);
}
.brandLogo {
  height: 48px;
  width: auto;
  display: block;
}
.brandName {
  font-family: var(--font-fraunces), Georgia, serif;
  font-weight: 600;
  font-size: 20px;
  letter-spacing: -0.01em;
}
.logomark {
  width: 32px;
  height: 32px;
  border-radius: 9px;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-900) 100%);
  display: grid;
  place-items: center;
  position: relative;
  box-shadow: 0 2px 8px rgba(63, 45, 24, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.1);
}
.logomark::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 9px;
  background: radial-gradient(circle at 30% 20%, rgba(239, 186, 129, 0.35), transparent 55%);
}
.logomark span {
  color: var(--gold);
  font-family: var(--font-fraunces), Georgia, serif;
  font-weight: 700;
  font-size: 16px;
  position: relative;
  z-index: 1;
}
.brandTag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gold-600);
  background: rgba(239, 186, 129, 0.12);
  padding: 3px 7px;
  border-radius: 4px;
}
.navLinks {
  display: flex;
  align-items: center;
  gap: 30px;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
}
.navWrap.scrolled .navLinks {
  color: var(--charcoal-80);
}
.navLinks a {
  position: relative;
  transition: color 0.2s;
  text-decoration: none;
  color: inherit;
}
.navLinks a:hover {
  color: #fff;
}
.navWrap.scrolled .navLinks a:hover {
  color: var(--navy);
}
.navLinks a::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -6px;
  height: 2px;
  background: var(--gold);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.navLinks a:hover::after {
  transform: scaleX(1);
}
.navCta {
  display: flex;
  align-items: center;
  gap: 12px;
}
.btnGhost {
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  padding: 9px 16px;
  border-radius: 8px;
  transition: background 0.2s, color 0.2s;
  text-decoration: none;
}
.btnGhost:hover {
  background: rgba(255, 255, 255, 0.1);
}
.navWrap.scrolled .btnGhost {
  color: var(--navy);
}
.navWrap.scrolled .btnGhost:hover {
  background: var(--surface-2);
}
.btnPrimary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 600;
  color: var(--navy);
  background: var(--gold);
  padding: 10px 18px;
  border-radius: 8px;
  box-shadow: 0 2px 10px rgba(239, 186, 129, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.3);
  transition: all 0.2s;
  border: none;
  cursor: pointer;
  text-decoration: none;
}
.btnPrimary:hover {
  background: var(--gold-300);
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(239, 186, 129, 0.35);
}
.btnPrimary .arrow {
  transition: transform 0.2s;
}
.btnPrimary:hover .arrow {
  transform: translateX(3px);
}
.khanMark {
  display: inline-flex;
  align-items: baseline;
  gap: 8px;
  text-decoration: none;
  padding: 6px 14px;
  border-left: 2px solid var(--gold);
  transition: opacity 0.2s;
}
.khanMark:hover {
  opacity: 0.85;
}
.khanMarkName {
  font-family: var(--font-fraunces), Georgia, serif;
  font-weight: 600;
  font-size: 17px;
  letter-spacing: -0.01em;
  color: #fff;
  line-height: 1;
  white-space: nowrap;
}
.navWrap.scrolled .khanMarkName {
  color: var(--navy);
}
.khanMarkPc {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--gold);
  line-height: 1;
}
.mobileToggle {
  display: none;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 8px;
  background: transparent;
  cursor: pointer;
  flex-shrink: 0;
}
.mobileToggle span,
.mobileToggle span::before,
.mobileToggle span::after {
  content: "";
  display: block;
  width: 18px;
  height: 2px;
  background: #fff;
  position: relative;
  transition: all 0.2s;
}
.mobileToggle span::before {
  position: absolute;
  top: -6px;
  left: 0;
}
.mobileToggle span::after {
  position: absolute;
  top: 6px;
  left: 0;
}
.navWrap.scrolled .mobileToggle {
  border-color: var(--line);
}
.navWrap.scrolled .mobileToggle span,
.navWrap.scrolled .mobileToggle span::before,
.navWrap.scrolled .mobileToggle span::after {
  background: var(--navy);
}

.mobileMenu {
  display: none;
  background: #fff;
  border-top: 1px solid var(--line);
  padding: 16px 24px 24px;
}
.mobileMenu.open {
  display: block;
}
.mobileMenu a {
  display: block;
  padding: 12px 0;
  font-size: 15px;
  font-weight: 500;
  color: var(--navy);
  border-bottom: 1px solid var(--line-2);
  text-decoration: none;
}
.mobileMenu a:last-child {
  border-bottom: none;
}
.mobileMenu a.btnPrimary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  margin-top: 16px;
  padding: 14px 18px;
  color: var(--navy);
  background: var(--gold);
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  white-space: nowrap;
}

/* ========= CONTAINERS ========= */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}
.containerSm {
  max-width: 1040px;
  margin: 0 auto;
  padding: 0 24px;
}
.containerXs {
  max-width: 820px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ========= HERO ========= */
.hero {
  position: relative;
  overflow: hidden;
  padding: 160px 0 120px;
  background:
    radial-gradient(ellipse 80% 60% at 20% 30%, rgba(239, 186, 129, 0.14) 0%, transparent 55%),
    radial-gradient(ellipse 60% 50% at 85% 20%, rgba(239, 186, 129, 0.08) 0%, transparent 55%),
    linear-gradient(180deg, var(--navy) 0%, var(--navy-800) 60%, var(--navy) 100%);
  color: #fff;
}
.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.04;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}
.hero::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -1px;
  width: 100%;
  height: 220px;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.06) 35%,
    rgba(255, 255, 255, 0.25) 65%,
    rgba(255, 255, 255, 0.7) 88%,
    #fff 100%
  );
  pointer-events: none;
}
.heroInner {
  position: relative;
  z-index: 2;
  text-align: center;
}
.heroEyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 7px 14px;
  border-radius: 999px;
  background: rgba(239, 186, 129, 0.12);
  border: 1px solid rgba(239, 186, 129, 0.28);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--gold-300);
  text-transform: uppercase;
}
.pulse {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--gold);
  box-shadow: 0 0 0 0 rgba(239, 186, 129, 0.6);
  animation: pulseAnim 2s infinite;
}
@keyframes pulseAnim {
  0%,
  100% {
    box-shadow: 0 0 0 0 rgba(239, 186, 129, 0.6);
  }
  50% {
    box-shadow: 0 0 0 8px rgba(239, 186, 129, 0);
  }
}
.page .heroTitle {
  margin-top: 28px;
  color: #fff;
  font-family: var(--font-fraunces), Georgia, serif;
  font-weight: 500;
  font-size: clamp(40px, 6vw, 76px);
  line-height: 1.02;
  letter-spacing: -0.035em;
}
.heroTitle em {
  font-style: italic;
  font-weight: 400;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-300) 50%, var(--gold) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.page .heroSub {
  box-sizing: border-box;
  max-width: min(720px, 100%);
  width: 100%;
  margin: 36px auto 0;
  padding: 0 clamp(16px, 4vw, 40px) 4px;
  text-align: center;
  text-wrap: balance;
  font-size: 19px;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.72);
  font-weight: 400;
}
.heroCta {
  margin-top: 40px;
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}
.btnLg {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 16px;
  font-weight: 600;
  padding: 16px 28px;
  border-radius: 10px;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  border: none;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
}
.btnGold {
  background: linear-gradient(180deg, var(--gold-300) 0%, var(--gold) 100%);
  color: var(--navy);
  box-shadow: 0 6px 24px rgba(239, 186, 129, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.4);
}
.btnGold:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 36px rgba(239, 186, 129, 0.5);
}
.btnGlass {
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10px);
}
.btnGlass:hover {
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.28);
}

.trustBar {
  margin-top: 64px;
  padding: 24px 32px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  text-align: left;
}
.trustItem {
  display: flex;
  align-items: center;
  gap: 12px;
}
.trustNum {
  font-family: var(--font-fraunces), serif;
  font-size: 32px;
  font-weight: 600;
  color: var(--gold);
  line-height: 1;
}
.trustLabel {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.35;
}

.floatCard {
  position: absolute;
  z-index: 1;
  border-radius: 14px;
  padding: 14px 16px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.22);
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  gap: 10px;
}
.floatIc {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  background: var(--gold);
  color: var(--navy);
  display: grid;
  place-items: center;
  font-weight: 700;
}
.fc1 {
  top: 180px;
  left: 4%;
  animation: floatAnim 7s ease-in-out infinite;
}
.fc2 {
  top: 260px;
  right: 6%;
  animation: floatAnim 7s ease-in-out 2s infinite;
}
.fc3 {
  bottom: 300px;
  left: 8%;
  animation: floatAnim 9s ease-in-out 1s infinite;
}
@keyframes floatAnim {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-16px);
  }
}

/* ========= LOGO BAR ========= */
.logobar {
  padding: 40px 0 20px;
  border-bottom: 1px solid var(--line-2);
}
.logobarLabel {
  text-align: center;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--charcoal-60);
  font-weight: 600;
}
.logobarRow {
  margin-top: 24px;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 28px;
  align-items: center;
  opacity: 0.55;
  filter: grayscale(1);
}
.logobarRow > div {
  font-family: var(--font-fraunces), serif;
  font-weight: 600;
  font-size: 18px;
  color: var(--navy);
  text-align: center;
  letter-spacing: -0.02em;
}

/* ========= SECTION ========= */
.section {
  padding: 110px 0;
  position: relative;
}
.sectionEyebrow {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold-600);
  margin-bottom: 14px;
}
.sectionHead {
  text-align: center;
  max-width: 780px;
  margin: 0 auto 64px;
}
.sectionHead h2 {
  font-family: var(--font-fraunces), Georgia, serif;
  font-weight: 500;
  font-size: clamp(32px, 4.2vw, 52px);
  line-height: 1.08;
  color: var(--navy);
}
.sectionHead p {
  margin-top: 18px;
  font-size: 18px;
  color: var(--charcoal-60);
  line-height: 1.5;
}

/* ========= PROBLEM / SOLUTION ========= */
.psGrid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.psCard {
  padding: 40px;
  border-radius: 20px;
  position: relative;
  overflow: hidden;
}
.psProblem {
  background: var(--surface);
  border: 1px solid var(--line);
}
.psSolution {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: #fff;
  box-shadow: 0 24px 60px -20px rgba(63, 45, 24, 0.35);
}
.psSolution::before {
  content: "";
  position: absolute;
  top: -60px;
  right: -60px;
  width: 220px;
  height: 220px;
  background: radial-gradient(circle, rgba(239, 186, 129, 0.25), transparent 70%);
}
.psTag {
  display: inline-block;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 5px 10px;
  border-radius: 5px;
}
.psProblem .psTag {
  background: #fef2f2;
  color: #b91c1c;
}
.psSolution .psTag {
  background: rgba(239, 186, 129, 0.2);
  color: var(--gold-300);
}
.psCard h3 {
  font-family: var(--font-fraunces), serif;
  font-weight: 500;
  font-size: 28px;
  line-height: 1.15;
  margin-top: 16px;
}
.psSolution h3 {
  color: #fff;
}
.psCard ul {
  list-style: none;
  padding: 0;
  margin: 24px 0 0;
}
.psCard ul li {
  display: flex;
  gap: 12px;
  padding: 10px 0;
  font-size: 15px;
  line-height: 1.5;
}
.psProblem ul li {
  color: var(--charcoal-80);
  border-bottom: 1px solid var(--line-2);
}
.psProblem ul li:last-child {
  border-bottom: none;
}
.psSolution ul li {
  color: rgba(255, 255, 255, 0.85);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}
.psSolution ul li:last-child {
  border-bottom: none;
}
.iconX {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #fee2e2;
  color: #b91c1c;
  display: grid;
  place-items: center;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}
.iconCheck {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--gold);
  color: var(--navy);
  display: grid;
  place-items: center;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}

/* ========= HOW IT WORKS ========= */
.howWrap {
  background: var(--surface);
}
.howGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  position: relative;
}
.howLine {
  position: absolute;
  top: 30px;
  left: 8%;
  right: 8%;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--gold) 20%, var(--gold) 80%, transparent 100%);
  opacity: 0.4;
}
.howStep {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 32px 24px 28px;
  position: relative;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.howStep:hover {
  transform: translateY(-4px);
  border-color: var(--gold);
  box-shadow: 0 16px 40px -10px rgba(63, 45, 24, 0.12);
}
.howNum {
  width: 60px;
  height: 60px;
  border-radius: 16px;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: var(--gold);
  display: grid;
  place-items: center;
  font-family: var(--font-fraunces), serif;
  font-weight: 600;
  font-size: 26px;
  box-shadow: 0 6px 20px -4px rgba(63, 45, 24, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  position: relative;
  z-index: 2;
}
.howStep h3 {
  margin-top: 22px;
  font-size: 18px;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.25;
}
.howStep p {
  margin-top: 10px;
  font-size: 14px;
  color: var(--charcoal-60);
  line-height: 1.55;
}

/* ========= DEMO ========= */
.demoStage {
  position: relative;
  margin: 48px auto 0;
  max-width: 1040px;
}
.demoStage::before,
.demoStage::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  filter: blur(60px);
}
.demoStage::before {
  top: -30px;
  left: -40px;
  width: 280px;
  height: 280px;
  background: rgba(239, 186, 129, 0.18);
}
.demoStage::after {
  bottom: -40px;
  right: -40px;
  width: 320px;
  height: 320px;
  background: rgba(63, 45, 24, 0.15);
}
.demoTopBar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  max-width: 920px;
  margin: 0 auto;
}
.demoTabs {
  display: flex;
  justify-content: center;
  gap: 4px;
  flex-wrap: nowrap;
  padding: 5px;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(14px);
  border: 1px solid var(--line);
  border-radius: 999px;
  width: fit-content;
  box-shadow: 0 2px 14px rgba(63, 45, 24, 0.06);
}
.iframeSkeleton {
  position: absolute;
  top: 42px;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  background: var(--surface);
  padding: 32px 36px;
  border-radius: 0 0 20px 20px;
}
.skeletonBar {
  border-radius: 8px;
  background: linear-gradient(90deg, var(--line) 0%, var(--line-2) 50%, var(--line) 100%);
  background-size: 200% 100%;
  animation: shimmer 1.4s ease infinite;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.demoIframe {
  display: block;
  width: 100%;
  height: 680px;
  border: none;
  border-radius: 0 0 20px 20px;
}
.demoOpenBtn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 16px;
  border-radius: 999px;
  background: var(--navy);
  color: var(--gold);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .02em;
  text-decoration: none;
  white-space: nowrap;
  transition: opacity .2s;
  box-shadow: 0 2px 8px rgba(63,45,24,.18);
}
.demoOpenBtn:hover {
  opacity: .85;
}
.demoTab {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 14px;
  border-radius: 999px;
  border: none;
  background: transparent;
  font-size: 13px;
  font-weight: 600;
  color: var(--charcoal-60);
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  white-space: nowrap;
  flex-shrink: 0;
  font-family: inherit;
}
.demoTab svg {
  width: 15px;
  height: 15px;
  opacity: 0.6;
  transition: opacity 0.2s;
  flex-shrink: 0;
}
.demoTab .tn {
  font-size: 10px;
  font-weight: 700;
  opacity: 0.5;
  background: var(--line-2);
  padding: 2px 6px;
  border-radius: 999px;
  color: var(--navy);
  letter-spacing: 0.02em;
}
.demoTabActive {
  background: linear-gradient(180deg, var(--navy) 0%, var(--navy-800) 100%);
  color: #fff;
  box-shadow: 0 6px 18px -4px rgba(63, 45, 24, 0.3);
}
.demoTabActive svg {
  opacity: 1;
  color: var(--gold);
}
.demoTabActive .tn {
  background: rgba(239, 186, 129, 0.25);
  color: var(--gold-300);
  opacity: 1;
}
.demoTab:not(.demoTabActive):hover {
  color: var(--navy);
  background: var(--surface);
}

.subTabs {
  display: flex;
  gap: 2px;
  padding: 8px 16px 0;
  border-bottom: 1px solid var(--line);
  background: rgba(250, 245, 238, 0.6);
}
.subTab {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  border: none;
  background: transparent;
  font-size: 11px;
  font-weight: 600;
  color: var(--charcoal-60);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: all 0.2s;
  font-family: inherit;
  white-space: nowrap;
}
.subTab .tn {
  font-size: 9px;
  font-weight: 700;
  opacity: 0.5;
  background: var(--line-2);
  padding: 1px 5px;
  border-radius: 999px;
  color: var(--navy);
}
.subTabActive {
  color: var(--navy);
  border-bottom-color: var(--navy);
}
.subTabActive .tn {
  background: var(--navy);
  color: #fff;
  opacity: 1;
}
.subTab:not(.subTabActive):hover {
  color: var(--navy);
  background: var(--surface);
}

.device {
  position: relative;
  z-index: 1;
  margin: 28px auto 0;
  max-width: 920px;
  border-radius: 22px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 0 0 1px rgba(63, 45, 24, 0.06), 0 40px 80px -20px rgba(63, 45, 24, 0.35),
    0 14px 30px -10px rgba(63, 45, 24, 0.18);
}
.deviceChrome {
  background: linear-gradient(180deg, #1b1410 0%, #2d2018 100%);
  padding: 10px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.deviceDots {
  display: flex;
  gap: 6px;
}
.deviceDots span {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  box-shadow: inset 0 -1px 0 rgba(0, 0, 0, 0.15);
}
.deviceDots span:nth-child(1) {
  background: #ff5f57;
}
.deviceDots span:nth-child(2) {
  background: #febc2e;
}
.deviceDots span:nth-child(3) {
  background: #28c840;
}
.deviceUrl {
  flex: 1;
  max-width: 360px;
  margin: 0 auto;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 8px;
  padding: 6px 12px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.7);
  font-family: ui-monospace, monospace;
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: center;
}
.deviceUrl .lock path {
  stroke: var(--gold-300);
}
.deviceActions {
  display: flex;
  gap: 6px;
}
.deviceActions span {
  width: 22px;
  height: 22px;
  border-radius: 5px;
  background: rgba(255, 255, 255, 0.06);
  display: grid;
  place-items: center;
}
.deviceActions span svg {
  width: 13px;
  height: 13px;
  color: rgba(255, 255, 255, 0.55);
}

.appTop {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 24px;
  background: #fff;
  border-bottom: 1px solid var(--line-2);
}
.firm {
  display: flex;
  align-items: center;
  gap: 10px;
}
.firmLogo {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: var(--gold);
  display: grid;
  place-items: center;
  font-family: var(--font-fraunces), serif;
  font-weight: 600;
  font-size: 14px;
}
.firmMeta .fn {
  font-weight: 600;
  color: var(--navy);
  font-size: 13px;
  letter-spacing: -0.01em;
}
.firmMeta .fs {
  font-size: 10px;
  color: var(--charcoal-60);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-weight: 600;
}
.appActions {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 12px;
  color: var(--charcoal-60);
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(34, 197, 94, 0.08);
  color: #16a34a;
  font-weight: 600;
  font-size: 11px;
}
.chip .dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #16a34a;
  animation: pulseAnim 2s infinite;
}
.appAvatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5d4b2, #efba81);
  color: var(--navy);
  display: grid;
  place-items: center;
  font-size: 11px;
  font-weight: 700;
}

.deviceBody {
  position: relative;
  min-height: 460px;
  background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(239, 186, 129, 0.06), transparent 70%),
    linear-gradient(180deg, #faf5ee 0%, #fff 100%);
}
.panel {
  position: absolute;
  inset: 0;
  padding: 32px 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: auto;
  opacity: 0;
  pointer-events: none;
  transform: translateY(12px);
  transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.panelOn {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}
.panelInner {
  width: 100%;
  max-width: 820px;
  margin: auto;
}

/* quiz */
.quizShell {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 24px;
  align-items: stretch;
  width: 100%;
}
.quizSide {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 18px;
  box-shadow: 0 4px 18px -6px rgba(63, 45, 24, 0.06);
  display: flex;
  flex-direction: column;
}
.quizSide .quizSteps {
  flex: 1;
  justify-content: center;
}
.quizSide h4 {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--charcoal-60);
}
.quizSteps {
  list-style: none;
  padding: 0;
  margin: 14px 0 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.quizSteps li {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 8px;
  border-radius: 7px;
  font-size: 12px;
  color: var(--charcoal-60);
  font-weight: 500;
}
.quizSteps li.done {
  color: var(--charcoal-80);
}
.quizSteps li.now {
  background: rgba(239, 186, 129, 0.1);
  color: var(--navy);
  font-weight: 600;
}
.quizSteps .sd {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: grid;
  place-items: center;
  flex-shrink: 0;
  background: var(--line-2);
  color: var(--charcoal-60);
  font-size: 9px;
  font-weight: 700;
}
.quizSteps li.done .sd {
  background: var(--gold);
  color: var(--navy);
}
.quizSteps li.now .sd {
  background: var(--navy);
  color: var(--gold);
  box-shadow: 0 0 0 4px rgba(239, 186, 129, 0.15);
}
.quizMain {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 32px;
  box-shadow: 0 8px 30px -10px rgba(63, 45, 24, 0.12);
}
.quizBarRow {
  display: flex;
  align-items: center;
  gap: 12px;
}
.quizStepTag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold-600);
  flex-shrink: 0;
}
.quizBar {
  flex: 1;
  height: 5px;
  background: var(--line-2);
  border-radius: 999px;
  overflow: hidden;
}
.quizBar i {
  display: block;
  height: 100%;
  width: 30%;
  background: linear-gradient(90deg, var(--gold-300), var(--gold));
  border-radius: 999px;
}
.quizPct {
  font-size: 11px;
  font-weight: 700;
  color: var(--navy);
}
.quizQ {
  margin-top: 20px;
  font-family: var(--font-fraunces), serif;
  font-size: 26px;
  font-weight: 500;
  color: var(--navy);
  line-height: 1.2;
  letter-spacing: -0.01em;
}
.quizHelp {
  margin-top: 8px;
  font-size: 13px;
  color: var(--charcoal-60);
  line-height: 1.5;
}
.quizOpts {
  margin-top: 22px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.quizOpt {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px;
  border: 1.5px solid var(--line);
  border-radius: 12px;
  font-weight: 600;
  font-size: 14px;
  color: var(--charcoal-80);
  background: #fff;
}
.quizOpt .kbd {
  font-family: ui-monospace, monospace;
  font-size: 10px;
  color: var(--charcoal-60);
  background: var(--surface);
  padding: 2px 6px;
  border-radius: 4px;
  border: 1px solid var(--line-2);
  margin-left: auto;
}
.quizOptSel {
  border-color: var(--gold);
  background: rgba(239, 186, 129, 0.08);
  color: var(--navy);
  box-shadow: 0 0 0 3px rgba(239, 186, 129, 0.12);
}
.quizCheckBox {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1.5px solid var(--line);
}
.quizCheckBoxSel {
  background: var(--gold);
  color: var(--navy);
  display: grid;
  place-items: center;
  font-size: 10px;
  font-weight: 900;
  border: none;
}
.quizFoot {
  margin-top: 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.quizBack {
  font-size: 13px;
  font-weight: 600;
  color: var(--charcoal-60);
  display: flex;
  align-items: center;
  gap: 6px;
}
.quizNext {
  padding: 12px 22px;
  border-radius: 10px;
  background: linear-gradient(180deg, var(--navy) 0%, var(--navy-800) 100%);
  color: #fff;
  font-weight: 600;
  font-size: 13px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 6px 16px -4px rgba(63, 45, 24, 0.3);
}

/* results */
.recWrap {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
  gap: 18px;
  align-items: stretch;
  width: 100%;
}
.recPrimary {
  position: relative;
  overflow: hidden;
  min-width: 0;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: #fff;
  border-radius: 14px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  box-shadow: 0 14px 40px -14px rgba(63, 45, 24, 0.35);
}
.recPrimary::before {
  content: "";
  position: absolute;
  top: -40px;
  right: -40px;
  width: 160px;
  height: 160px;
  background: radial-gradient(circle, rgba(239, 186, 129, 0.3), transparent 70%);
  pointer-events: none;
}
.recPrimary > * {
  position: relative;
  z-index: 1;
}
.recTag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  align-self: flex-start;
  padding: 4px 9px;
  border-radius: 999px;
  background: rgba(239, 186, 129, 0.15);
  color: var(--gold-300);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.recPrimary h3 {
  color: #fff;
  font-family: var(--font-fraunces), serif;
  font-size: 16px;
  font-weight: 500;
  margin-top: 8px;
  line-height: 1.22;
  letter-spacing: -0.01em;
}
.recPrimary h3 em {
  color: var(--gold-300);
  font-style: italic;
}
.recWhy {
  margin-top: 6px;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
}
.recPricebox {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.recPricebox .pl {
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 700;
}
.recPricebox .pv {
  font-family: var(--font-fraunces), serif;
  font-size: 22px;
  color: #fff;
  font-weight: 500;
  line-height: 1.1;
  margin-top: 2px;
}
.recBullets {
  margin: 8px 0 0;
  padding: 0;
  list-style: none;
}
.recBullets li {
  display: flex;
  gap: 8px;
  padding: 2px 0;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.35;
}
.recBullets li svg {
  flex-shrink: 0;
  margin-top: 3px;
  color: var(--gold-300);
  width: 12px;
  height: 12px;
}
.recCta {
  margin-top: 10px;
  padding: 9px;
  border-radius: 9px;
  background: linear-gradient(180deg, var(--gold-300) 0%, var(--gold) 100%);
  color: var(--navy);
  text-align: center;
  font-weight: 700;
  font-size: 13px;
  box-shadow: 0 4px 14px rgba(239, 186, 129, 0.4);
}
.recAlt {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 13px;
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.recAlt h4 {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--charcoal-60);
}
.recAltCard {
  padding: 9px 11px;
  border: 1.5px solid var(--line-2);
  border-radius: 10px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}
.recAltCard .nm {
  font-weight: 600;
  color: var(--navy);
  font-size: 13px;
  line-height: 1.2;
}
.recAltCard .ds {
  font-size: 11px;
  color: var(--charcoal-60);
  margin-top: 2px;
}
.recAltCard .pr {
  font-family: var(--font-fraunces), serif;
  font-size: 16px;
  font-weight: 600;
  color: var(--navy);
  flex-shrink: 0;
}
.recAltRow {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-top: 8px;
}
.recTrust {
  margin-top: auto;
  padding-top: 10px;
  border-top: 1px dashed var(--line);
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 11px;
  color: var(--charcoal-60);
  line-height: 1.45;
}
.recTrust svg {
  color: var(--gold-600);
  flex-shrink: 0;
  margin-top: 1px;
  width: 14px;
  height: 14px;
}

/* docs */
.docsHero {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border-radius: 12px;
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.06) 0%, rgba(34, 197, 94, 0.02) 100%);
  border: 1px solid rgba(34, 197, 94, 0.18);
  margin-bottom: 12px;
}
.dhIc {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: rgba(34, 197, 94, 0.15);
  color: #16a34a;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}
.dhT {
  font-family: var(--font-fraunces), serif;
  font-size: 15px;
  color: var(--navy);
  font-weight: 500;
}
.dhS {
  font-size: 11px;
  color: var(--charcoal-60);
  margin-top: 2px;
}
.dhBadge {
  margin-left: auto;
  padding: 5px 10px;
  border-radius: 999px;
  background: rgba(34, 197, 94, 0.15);
  color: #16a34a;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
}
.docList {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.docItem {
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  align-items: center;
  gap: 12px;
  padding: 9px 12px;
  border: 1px solid var(--line);
  border-radius: 10px;
  background: #fff;
}
.docIc {
  width: 30px;
  height: 36px;
  border-radius: 5px;
  position: relative;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  display: grid;
  place-items: center;
  box-shadow: 0 3px 8px -2px rgba(63, 45, 24, 0.3);
}
.docIc::before {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  width: 10px;
  height: 10px;
  background: var(--gold);
  clip-path: polygon(0 0, 100% 100%, 100% 0);
}
.dx {
  color: var(--gold);
  font-family: var(--font-fraunces), serif;
  font-weight: 700;
  font-size: 10px;
}
.docInfo .dn {
  font-size: 12px;
  font-weight: 600;
  color: var(--navy);
}
.docInfo .dm {
  font-size: 10px;
  color: var(--charcoal-60);
  margin-top: 2px;
  display: flex;
  gap: 8px;
  align-items: center;
}
.docInfo .dm .sep {
  width: 3px;
  height: 3px;
  background: var(--charcoal-60);
  border-radius: 50%;
  opacity: 0.5;
}
.docSig {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 5px;
  background: rgba(239, 186, 129, 0.15);
  color: var(--gold-600);
}
.docDl {
  width: 28px;
  height: 28px;
  border-radius: 7px;
  background: var(--surface);
  display: grid;
  place-items: center;
  color: var(--navy);
}

/* vault */
.vaultHead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: #fff;
  margin-bottom: 16px;
}
.vt {
  display: flex;
  align-items: center;
  gap: 12px;
}
.vic {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: var(--gold);
  display: grid;
  place-items: center;
}
.vl {
  font-family: var(--font-fraunces), serif;
  font-size: 16px;
  color: var(--navy);
  font-weight: 500;
}
.vs {
  font-size: 11px;
  color: var(--charcoal-60);
  display: flex;
  align-items: center;
  gap: 6px;
}
.vs::before {
  content: "";
  width: 6px;
  height: 6px;
  background: #16a34a;
  border-radius: 50%;
}
.vaultPin {
  display: flex;
  align-items: center;
  gap: 10px;
}
.pinDots {
  display: flex;
  gap: 4px;
}
.pinDots span {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--navy);
}
.pinLabel {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--charcoal-60);
}
.vaultGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}
.vaultItem {
  padding: 16px 12px;
  border-radius: 12px;
  background: #fff;
  border: 1px solid var(--line);
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 110px;
  position: relative;
}
.vaultItemActive {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  border-color: transparent;
  color: #fff;
  box-shadow: 0 10px 26px -8px rgba(63, 45, 24, 0.4);
}
.vi {
  width: 32px;
  height: 32px;
  border-radius: 9px;
  background: var(--surface);
  color: var(--navy);
  display: grid;
  place-items: center;
}
.vaultItemActive .vi {
  background: rgba(239, 186, 129, 0.2);
  color: var(--gold-300);
}
.vn {
  font-size: 11px;
  font-weight: 600;
  color: var(--navy);
  line-height: 1.3;
}
.vaultItemActive .vn {
  color: #fff;
}
.vc {
  font-size: 10px;
  color: var(--charcoal-60);
  margin-top: auto;
  font-weight: 500;
}
.vaultItemActive .vc {
  color: var(--gold-300);
}
.vbadge {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--gold);
  color: var(--navy);
  font-size: 9px;
  font-weight: 700;
  display: grid;
  place-items: center;
}

/* review */
.revGrid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 18px;
}
.revList {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  overflow: hidden;
}
.revListHead {
  padding: 14px 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--surface);
  border-bottom: 1px solid var(--line-2);
}
.revListHead h4 {
  font-size: 12px;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: -0.01em;
}
.rct {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: var(--charcoal-60);
  background: #fff;
  padding: 3px 8px;
  border-radius: 999px;
  border: 1px solid var(--line);
}
.revRow {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--line-2);
}
.revRowSel {
  background: rgba(239, 186, 129, 0.08);
  border-left: 3px solid var(--gold);
  padding-left: 13px;
}
.av {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5d4b2, #efba81);
  color: var(--navy);
  display: grid;
  place-items: center;
  font-weight: 700;
  font-size: 12px;
  flex-shrink: 0;
}
.rn {
  font-size: 13px;
  font-weight: 600;
  color: var(--navy);
}
.rp {
  font-size: 11px;
  color: var(--charcoal-60);
}
.rt {
  margin-left: auto;
  font-size: 10px;
  font-weight: 700;
  color: var(--charcoal-60);
}
.urg {
  color: #dc2626;
}
.revDetail {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.revDetailTop {
  padding: 16px;
  border-bottom: 1px solid var(--line-2);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14px;
}
.rdl {
  font-family: var(--font-fraunces), serif;
  font-size: 15px;
  color: var(--navy);
  font-weight: 500;
}
.rds {
  font-size: 11px;
  color: var(--charcoal-60);
  margin-top: 3px;
}
.revSla {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 4px 9px;
  border-radius: 999px;
  background: #fef3c7;
  color: #92400e;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 5px;
}
.spdot {
  width: 5px;
  height: 5px;
  background: #92400e;
  border-radius: 50%;
  animation: pulseAnim 2s infinite;
}
.revPage {
  flex: 1;
  padding: 14px;
  background: linear-gradient(90deg, var(--line-2) 0 1px, transparent 1px) 0 0 / 100% 22px;
  background-color: #faf5ee;
  font-size: 10px;
  color: var(--charcoal-60);
  line-height: 22px;
  font-family: ui-monospace, monospace;
}
.revPage .hl {
  background: rgba(239, 186, 129, 0.2);
  padding: 0 3px;
  color: var(--navy);
  font-weight: 600;
}
.revActions {
  padding: 14px;
  border-top: 1px solid var(--line-2);
  display: flex;
  gap: 8px;
}
.revBtn {
  flex: 1;
  padding: 11px;
  border-radius: 9px;
  font-weight: 600;
  font-size: 12px;
  text-align: center;
}
.revBtnPrimary {
  background: linear-gradient(180deg, var(--gold-300) 0%, var(--gold) 100%);
  color: var(--navy);
  box-shadow: 0 3px 10px rgba(239, 186, 129, 0.3);
}
.revBtnGhost {
  background: var(--surface);
  color: var(--navy);
}

.demoCaption {
  display: flex;
  align-items: center;
  gap: 14px;
  margin: 22px auto 0;
  max-width: 640px;
  padding: 14px 18px;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  border: 1px solid var(--line);
  border-radius: 14px;
  font-size: 13px;
  color: var(--charcoal-80);
  line-height: 1.5;
}
.captionIc {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: rgba(239, 186, 129, 0.15);
  color: var(--gold-600);
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

/* ========= PRICING ========= */
.priceWrap {
  background: var(--surface);
}
.promoBox {
  margin: 0 auto 24px;
  max-width: 460px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 12px;
  box-shadow: 0 4px 14px rgba(63, 45, 24, 0.05);
}
.promoBox input {
  flex: 1;
  border: none;
  padding: 10px 14px;
  font-size: 14px;
  font-family: inherit;
  outline: none;
  color: var(--navy);
  background: transparent;
}
.promoBox input::placeholder {
  color: var(--charcoal-60);
}
.promoBox button {
  padding: 10px 18px;
  border: none;
  border-radius: 9px;
  background: var(--navy);
  color: #fff;
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: background 0.2s;
  font-family: inherit;
}
.promoBox button:hover {
  background: var(--navy-800);
}
.promoMsg {
  text-align: center;
  margin-top: 0;
  font-size: 13px;
  font-weight: 600;
  min-height: 20px;
}
.promoOk {
  color: #16a34a;
}
.promoErr {
  color: #dc2626;
}

.planGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  align-items: stretch;
  margin-top: 48px;
  padding-bottom: 48px;
}
.plan {
  position: relative;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.plan:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 48px -16px rgba(63, 45, 24, 0.15);
}
.planFeatured {
  border: 2px solid var(--gold);
  box-shadow: 0 20px 60px -16px rgba(239, 186, 129, 0.28);
  transform: scale(1.02);
}
.planFeatured:hover {
  transform: scale(1.02) translateY(-4px);
}
.planBadge {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(180deg, var(--gold-300) 0%, var(--gold) 100%);
  color: var(--navy);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 999px;
  box-shadow: 0 4px 14px rgba(239, 186, 129, 0.4);
  white-space: nowrap;
}
.plan h3 {
  font-family: var(--font-fraunces), serif;
  font-size: 26px;
  font-weight: 500;
  color: var(--navy);
}
.planSub {
  font-size: 13px;
  color: var(--charcoal-60);
  margin-top: 4px;
}
.planPrice {
  margin: 22px 0 4px;
  display: flex;
  align-items: baseline;
  gap: 8px;
  flex-wrap: wrap;
}
.planPriceBig {
  font-family: var(--font-fraunces), serif;
  font-size: 46px;
  font-weight: 600;
  color: var(--navy);
  letter-spacing: -0.02em;
  line-height: 1;
}
.planPriceFree {
  color: #16a34a;
}
.planPriceSmall {
  font-size: 14px;
  color: var(--charcoal-60);
}
.planPriceCrossed {
  font-size: 18px;
  color: var(--charcoal-60);
  text-decoration: line-through;
}
.planTerms {
  font-size: 12px;
  color: var(--charcoal-60);
}
.planDivider {
  height: 1px;
  background: var(--line-2);
  margin: 28px 0;
}
.plan ul {
  list-style: none;
  padding: 0;
  margin: 0 0 32px;
  flex: 1;
}
.plan ul li {
  display: flex;
  gap: 10px;
  font-size: 14px;
  color: var(--charcoal-80);
  line-height: 1.5;
  padding: 8px 0;
}
.plan ul li svg {
  flex-shrink: 0;
  margin-top: 3px;
  color: var(--gold);
}
.planCta {
  display: block;
  text-align: center;
  padding: 15px;
  border-radius: 12px;
  font-size: 15px;
  font-weight: 700;
  transition: all 0.2s;
  text-decoration: none;
  cursor: pointer;
  font-family: inherit;
  border: none;
  width: 100%;
}
.planCtaGold {
  background: linear-gradient(180deg, var(--gold-300) 0%, var(--gold) 100%);
  color: var(--navy);
  box-shadow: 0 4px 14px rgba(239, 186, 129, 0.3);
}
.planCtaGold:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(239, 186, 129, 0.4);
}
.planCtaNavy {
  background: var(--navy);
  color: #fff;
}
.planCtaNavy:hover {
  background: var(--navy-800);
}
.planCtaOutline {
  border: 1.5px solid var(--navy);
  color: var(--navy);
  background: transparent;
}
.planCtaOutline:hover {
  background: var(--navy);
  color: #fff;
}
.planNote {
  margin-top: 64px;
  text-align: center;
  font-size: 13px;
  color: var(--charcoal-60);
}
.planNote code {
  background: rgba(239, 186, 129, 0.12);
  color: var(--gold-600);
  padding: 2px 8px;
  border-radius: 5px;
  font-family: ui-monospace, monospace;
  font-size: 12px;
}

.referral {
  margin-top: 40px;
  padding: 36px;
  border-radius: 20px;
  background: linear-gradient(135deg, #fff 0%, #faf5ee 100%);
  border: 1px dashed var(--gold);
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 32px;
  align-items: center;
}
.referral h3 {
  font-family: var(--font-fraunces), serif;
  font-size: 24px;
  font-weight: 500;
  color: var(--navy);
}
.referral h3 em {
  font-style: normal;
  color: var(--gold-600);
}
.referral ul {
  list-style: none;
  padding: 0;
  margin: 18px 0 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.referral ul li {
  display: flex;
  gap: 8px;
  font-size: 13px;
  color: var(--charcoal-80);
  line-height: 1.45;
}
.referral ul li::before {
  content: "✓";
  color: var(--gold-600);
  font-weight: 700;
}
.referralCta {
  text-align: right;
}
.referralCta a,
.referralCta button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 24px;
  background: var(--navy);
  color: #fff;
  font-weight: 600;
  font-size: 14px;
  border-radius: 10px;
  transition: background 0.2s;
  border: none;
  cursor: pointer;
  font-family: inherit;
  text-decoration: none;
}
.referralCta a:hover,
.referralCta button:hover {
  background: var(--navy-800);
}

/* ========= CALCULATOR ========= */
.calcWrap {
  background: #fff;
}
.calc {
  max-width: 780px;
  margin: 0 auto;
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 24px 60px -20px rgba(63, 45, 24, 0.15);
}
.calcToggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: var(--surface);
}
.calcToggle button {
  padding: 14px 16px;
  border: none;
  background: transparent;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  color: var(--charcoal-60);
  border-bottom: 3px solid transparent;
  transition: all 0.2s;
  font-family: inherit;
}
.calcToggle button:hover {
  color: var(--navy);
}
.calcToggleOn {
  background: #fff !important;
  color: var(--navy) !important;
  border-bottom-color: var(--gold) !important;
}
.calcBody {
  padding: 24px 28px;
}
.sliderBlock {
  margin-bottom: 20px;
}
.sliderBlock:last-child {
  margin-bottom: 0;
}
.sliderHead {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8px;
  gap: 12px;
}
.sliderLabel {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--charcoal-60);
}
.sliderVal {
  font-family: var(--font-fraunces), serif;
  font-size: 24px;
  font-weight: 600;
  color: var(--navy);
  line-height: 1;
}
.range {
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  height: 30px;
}
.range::-webkit-slider-runnable-track {
  height: 6px;
  background: var(--line-2);
  border-radius: 999px;
}
.range::-moz-range-track {
  height: 6px;
  background: var(--line-2);
  border-radius: 999px;
}
.range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold-300) 0%, var(--gold) 100%);
  border: 3px solid #fff;
  box-shadow: 0 2px 8px rgba(239, 186, 129, 0.45);
  margin-top: -8px;
  cursor: pointer;
  transition: transform 0.15s;
}
.range::-moz-range-thumb {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--gold-300) 0%, var(--gold) 100%);
  border: 3px solid #fff;
  box-shadow: 0 2px 8px rgba(239, 186, 129, 0.45);
  cursor: pointer;
}
.range::-webkit-slider-thumb:hover {
  transform: scale(1.15);
}
.sliderScale {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--charcoal-60);
  margin-top: 6px;
}
.sliderNote {
  margin-top: 6px;
  font-size: 11px;
  color: var(--charcoal-60);
}
.calcResults {
  background: var(--surface);
  padding: 4px;
}
.calcRow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 13px 24px;
  background: #fff;
  border-bottom: 1px solid var(--line-2);
  gap: 14px;
}
.calcRow:last-child {
  border-bottom: none;
}
.cl {
  font-weight: 600;
  color: var(--navy);
  font-size: 13px;
}
.cs {
  font-size: 11px;
  color: var(--charcoal-60);
  margin-top: 2px;
}
.cv {
  font-family: var(--font-fraunces), serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--navy);
  flex-shrink: 0;
  letter-spacing: -0.01em;
}
.calcRowGold {
  background: rgba(239, 186, 129, 0.06);
}
.calcRowGold .cl,
.calcRowGold .cv {
  color: var(--gold-600);
}
.calcTotal {
  padding: 24px 28px;
  text-align: center;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: #fff;
  position: relative;
  overflow: hidden;
}
.calcTotal::before {
  content: "";
  position: absolute;
  top: -40px;
  right: -40px;
  width: 180px;
  height: 180px;
  background: radial-gradient(circle, rgba(239, 186, 129, 0.2), transparent 70%);
}
.tlabel {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.6);
}
.tnum {
  font-family: var(--font-fraunces), serif;
  font-size: clamp(36px, 5.5vw, 52px);
  font-weight: 500;
  margin-top: 6px;
  line-height: 1;
  letter-spacing: -0.03em;
}
.tper {
  color: rgba(255, 255, 255, 0.6);
  font-size: 13px;
  margin-top: 4px;
}
.tpayback {
  margin-top: 12px;
  font-size: 13px;
  color: var(--gold-300);
  font-weight: 600;
  position: relative;
  z-index: 1;
}
.calcDisclaim {
  max-width: 680px;
  margin: 0 auto;
  padding-top: 50px;
  font-size: 12px;
  color: var(--charcoal-60);
  text-align: center;
  line-height: 1.55;
}

/* ========= UPSELL ========= */
.upsellWrap {
  background: linear-gradient(180deg, var(--navy-900) 0%, var(--navy) 100%);
  color: #fff;
  position: relative;
  overflow: hidden;
}
.upsellWrap::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 50% at 50% 0%, rgba(239, 186, 129, 0.15), transparent 60%),
    radial-gradient(ellipse 40% 60% at 15% 80%, rgba(239, 186, 129, 0.08), transparent 60%);
  pointer-events: none;
}
.upsellWrap .sectionHead h2 {
  color: #fff;
}
.upsellWrap .sectionHead p {
  color: rgba(255, 255, 255, 0.7);
}
.upsellWrap .sectionEyebrow {
  color: var(--gold-300);
}
.upsellGrid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  position: relative;
  z-index: 1;
}
.upsellCard {
  padding: 36px 28px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  text-align: center;
  transition: all 0.3s;
}
.upsellCard:hover {
  border-color: rgba(239, 186, 129, 0.3);
  transform: translateY(-4px);
}
.utype {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold-300);
}
.uprice {
  font-family: var(--font-fraunces), serif;
  font-size: 34px;
  font-weight: 500;
  margin-top: 12px;
  color: #fff;
}
.usub {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 6px;
}
.upsellFoot {
  margin-top: 0;
  padding-top: 64px;
  text-align: center;
  font-size: 18px;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 300;
  position: relative;
  z-index: 1;
}
.upsellFoot strong {
  color: #fff;
  font-weight: 600;
}

/* ========= TESTIMONIALS ========= */
.testimonialsWrap {
  background: var(--surface);
}
.tg {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.tcard {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 32px;
  position: relative;
  transition: all 0.3s;
}
.tcard:hover {
  border-color: var(--gold);
  box-shadow: 0 12px 32px -12px rgba(63, 45, 24, 0.12);
}
.tquote {
  font-family: var(--font-fraunces), serif;
  font-size: 54px;
  font-weight: 500;
  color: var(--gold);
  line-height: 0.5;
  position: absolute;
  top: 28px;
  right: 24px;
  opacity: 0.25;
}
.tstars {
  color: var(--gold);
  font-size: 14px;
  letter-spacing: 2px;
}
.tcopy {
  margin-top: 14px;
  font-size: 15px;
  line-height: 1.6;
  color: var(--charcoal-80);
}
.tauthor {
  margin-top: 22px;
  padding-top: 22px;
  border-top: 1px solid var(--line-2);
  display: flex;
  align-items: center;
  gap: 12px;
}
.tavatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-800) 100%);
  color: var(--gold);
  display: grid;
  place-items: center;
  font-family: var(--font-fraunces), serif;
  font-weight: 600;
  font-size: 16px;
}
.tname {
  font-weight: 600;
  color: var(--navy);
  font-size: 14px;
}
.trole {
  font-size: 12px;
  color: var(--charcoal-60);
}

/* ========= FAQ ========= */
.faqWrap {
  background: #fff;
}
.faq {
  max-width: 760px;
  margin: 0 auto;
}
.faqItem {
  border-bottom: 1px solid var(--line);
}
.faqQ {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
  padding: 24px 4px;
  width: 100%;
  background: transparent;
  border: none;
  font-family: inherit;
  font-size: 16px;
  font-weight: 600;
  color: var(--navy);
  text-align: left;
  cursor: pointer;
}
.faqQ:hover {
  color: var(--gold-600);
}
.faqChev {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--surface);
  display: grid;
  place-items: center;
  flex-shrink: 0;
  transition: all 0.3s;
}
.faqChev::before {
  content: "";
  width: 8px;
  height: 8px;
  border-right: 2px solid var(--navy);
  border-bottom: 2px solid var(--navy);
  transform: rotate(45deg) translateY(-2px);
  transition: transform 0.3s;
}
.faqItemOpen .faqChev {
  background: var(--gold);
}
.faqItemOpen .faqChev::before {
  transform: rotate(-135deg) translateY(-2px);
  border-color: var(--navy);
}
.faqA {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
.faqAInner {
  padding: 0 4px 24px;
  font-size: 15px;
  color: var(--charcoal-80);
  line-height: 1.65;
}

/* ========= COMPLIANCE ========= */
.compliance {
  background: var(--surface-2);
  padding: 60px 0;
  border-top: 1px solid var(--line);
}
.compInner {
  text-align: center;
  max-width: 720px;
  margin: 0 auto;
  padding: 0 24px;
}
.compInner h3 {
  font-family: var(--font-fraunces), serif;
  font-weight: 500;
  font-size: 22px;
  color: var(--navy);
}
.compInner p {
  margin-top: 14px;
  font-size: 14px;
  color: var(--charcoal-60);
  line-height: 1.65;
}

/* ========= FINAL CTA ========= */
.ctaWrap {
  padding: 110px 0;
  background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(239, 186, 129, 0.2), transparent 60%),
    linear-gradient(180deg, var(--navy) 0%, var(--navy-900) 100%);
  color: #fff;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.ctaWrap::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}
.ctaWrap h2 {
  color: #fff;
  font-family: var(--font-fraunces), serif;
  font-weight: 500;
  font-size: clamp(36px, 5vw, 60px);
  line-height: 1.05;
  position: relative;
  z-index: 1;
}
.ctaWrap h2 em {
  font-style: italic;
  color: var(--gold-300);
}
.ctaWrap p {
  margin-top: 22px;
  font-size: 18px;
  color: rgba(255, 255, 255, 0.7);
  max-width: 540px;
  margin-left: auto;
  margin-right: auto;
  position: relative;
  z-index: 1;
}
.ctaButtons {
  margin-top: 40px;
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}

/* ========= FOOTER ========= */
.footer {
  background: var(--navy-950);
  color: rgba(255, 255, 255, 0.55);
  padding: 60px 0 30px;
}
.footTop {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr 1fr;
  gap: 40px;
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}
.footBrand {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.footBrand .brand {
  color: #fff;
}
.footBrand p {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.6;
  max-width: 320px;
}
.footCol h4 {
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 14px;
}
.footCol ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.footCol ul a {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.55);
  transition: color 0.2s;
  text-decoration: none;
}
.footCol ul a:hover {
  color: var(--gold-300);
}
.footBot {
  margin-top: 30px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.6;
  text-align: center;
}

/* ========= REVEAL ========= */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
.revealIn {
  opacity: 1;
  transform: translateY(0);
}

/* ========= RESPONSIVE ========= */
@media (max-width: 1100px) {
  .planGrid {
    grid-template-columns: 1fr;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .planFeatured {
    transform: none;
  }
  .planFeatured:hover {
    transform: translateY(-4px);
  }
  .referral {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .referral ul {
    grid-template-columns: 1fr;
    text-align: left;
  }
  .referralCta {
    text-align: center;
  }
}
@media (max-width: 1000px) {
  .howGrid {
    grid-template-columns: repeat(2, 1fr);
  }
  .howLine {
    display: none;
  }
  .tg {
    grid-template-columns: 1fr;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }
}
@media (max-width: 900px) {
  .navLinks {
    display: none;
  }
  .navCta .btnGhost,
  .navCta .btnPrimary {
    display: none;
  }
  .khanMark {
    display: none;
  }
  .mobileToggle {
    display: flex;
  }
  .trustBar {
    grid-template-columns: repeat(2, 1fr);
    padding: 20px 22px;
    margin-top: 44px;
  }
  .hero {
    padding: 130px 0 90px;
  }
  .section {
    padding: 80px 0;
  }
  .sectionHead {
    margin-bottom: 48px;
  }
  .upsellFoot {
    padding-top: 48px;
  }
  .floatCard {
    display: none;
  }
  .psGrid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .logobarRow {
    grid-template-columns: repeat(2, 1fr);
  }
  .upsellGrid {
    grid-template-columns: 1fr;
  }
  .footTop {
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  .page .heroSub {
    font-size: 17px;
    text-align: center;
  }
  .faq {
    max-width: 100%;
  }
  .ctaButtons {
    flex-direction: column;
    align-items: stretch;
  }
}
@media (max-width: 860px) {
  .quizShell {
    grid-template-columns: 1fr;
  }
  .quizSide {
    display: none;
  }
  .recWrap {
    grid-template-columns: 1fr;
  }
  .revGrid {
    grid-template-columns: 1fr;
  }
  .vaultGrid {
    grid-template-columns: repeat(3, 1fr);
  }
  .panel {
    padding: 22px;
  }
  .demoTabs {
    max-width: 100%;
    width: 100%;
    justify-content: space-between;
    padding: 4px;
    gap: 2px;
  }
  .demoTab {
    padding: 8px 10px;
    font-size: 12px;
    gap: 5px;
    flex: 1;
    justify-content: center;
  }
  .demoTab .tn {
    display: none;
  }
  .demoTab svg {
    width: 13px;
    height: 13px;
  }
}
@media (max-width: 700px) {
  .calcToggle {
    grid-template-columns: 1fr;
  }
  .calcToggle button {
    padding: 14px;
    font-size: 13px;
  }
  .calcBody {
    padding: 28px 20px;
  }
  .calcRow {
    padding: 16px 22px;
  }
  .appTop {
    padding: 12px 16px;
  }
  .appActions .chip {
    display: none;
  }
  .docItem {
    grid-template-columns: auto 1fr auto;
    gap: 10px;
  }
  .docSig {
    display: none;
  }
  .vaultHead {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
}
@media (max-width: 560px) {
  .container,
  .containerSm,
  .containerXs {
    padding: 0 18px;
  }
  .trustBar {
    grid-template-columns: 1fr;
    padding: 18px 20px;
    gap: 10px;
  }
  .trustItem {
    padding: 8px 0;
  }
  .heroCta {
    flex-direction: column;
    align-items: stretch;
    margin-top: 32px;
  }
  .btnLg {
    justify-content: center;
    padding: 15px 22px;
    font-size: 15px;
  }
  .vaultGrid {
    grid-template-columns: repeat(2, 1fr);
  }
  .deviceBody {
    min-height: 540px;
  }
  .panel {
    padding: 18px 16px;
  }
  .quizMain {
    padding: 18px 16px;
  }
  .quizQ {
    font-size: 19px;
  }
  .quizOpts {
    grid-template-columns: 1fr;
  }
  .logobarRow {
    grid-template-columns: 1fr;
    gap: 14px;
  }
  .psCard {
    padding: 24px 20px;
  }
  .plan {
    padding: 26px 22px;
  }
  .referral {
    padding: 28px 22px;
  }
  .section {
    padding: 64px 0;
  }
  .sectionHead {
    margin-bottom: 36px;
  }
  .hero {
    padding: 110px 0 72px;
  }
  .heroTitle {
    font-size: clamp(34px, 9vw, 44px);
    margin-top: 20px;
  }
  .page .heroSub {
    font-size: 16px;
    margin-top: 24px;
    padding-inline: clamp(12px, 4vw, 28px);
    text-align: center;
  }
  .promoBox {
    padding: 20px;
  }
  .promoBox input {
    font-size: 15px;
  }
  .calcBody {
    padding: 20px 16px;
  }
  .calcRow {
    padding: 12px 16px;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }
  .cv {
    align-self: flex-end;
    font-size: 20px;
  }
  .calcTotal {
    padding: 22px 18px;
  }
  .tnum {
    font-size: clamp(32px, 10vw, 44px);
  }
  .sliderVal {
    font-size: 22px;
  }
  .calcDisclaim {
    padding-top: 96px;
  }
  .upsellFoot {
    padding-top: 36px;
    font-size: 16px;
  }
  .faqQ {
    padding: 18px 4px;
    font-size: 15px;
  }
  .faqAInner {
    padding: 0 4px 18px;
    font-size: 14px;
  }
  .compliance {
    padding: 48px 0;
  }
  .compInner h3 {
    font-size: 20px;
  }
  .ctaWrap h2 {
    font-size: clamp(28px, 7vw, 40px);
  }
  .footTop {
    grid-template-columns: 1fr;
  }
  .footBot {
    text-align: center;
  }
  .demoTab {
    padding: 7px 6px;
    font-size: 11px;
    gap: 4px;
  }
  .demoTab svg {
    display: none;
  }
  .docsHero {
    flex-wrap: wrap;
  }
  .dhBadge {
    margin-left: 0;
  }
}
@media (max-width: 420px) {
  .heroTitle {
    font-size: clamp(30px, 9vw, 38px);
  }
  .sectionHead h2 {
    font-size: clamp(26px, 7.5vw, 36px);
  }
  .section {
    padding: 52px 0;
  }
  .deviceBody {
    min-height: 500px;
  }
  .trustNum {
    font-size: 26px;
  }
  .vaultGrid {
    grid-template-columns: 1fr;
  }
}
