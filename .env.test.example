# Copy to .env.test and fill with TEST Supabase project values. NEVER point at prod.
TEST_MODE=1

# Test Supabase project (separate from prod)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Whitelist URL (must equal NEXT_PUBLIC_SUPABASE_URL OR url must contain "test")
TEST_SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co

# Stripe test mode
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Anthropic (use a low-quota key for tests)
ANTHROPIC_API_KEY=

# Resend (use test key — emails will not deliver)
RESEND_API_KEY=

# E2E
TEST_BASE_URL=http://localhost:3000
TEST_PORT=3000
